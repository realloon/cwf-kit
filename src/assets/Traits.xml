  <!-- GrenadeLauncher -->
  <WeaponTraitDef>
    <defName>CWF_Trait_GrenadeLauncher</defName>
    <label>grenade launcher</label>
    <description>.</description>
    <commonality>1</commonality>
    <statOffsets>
      <MarketValue>50</MarketValue>
      <Mass>0.1</Mass>
    </statOffsets>
    <abilityProps>
      <abilityDef>LaunchFragGrenade</abilityDef>
      <maxCharges>1</maxCharges>
      <soundReload>Standard_Reload</soundReload>
      <chargeNoun>grenade</chargeNoun>
      <ammoDef>Steel</ammoDef>
      <ammoCountPerCharge>25</ammoCountPerCharge>
      <baseReloadTicks>60</baseReloadTicks>
    </abilityProps>
  </WeaponTraitDef>

  <!-- EMPLauncher -->
  <WeaponTraitDef>
    <defName>CWF_Trait_EMPLauncher</defName>
    <label>EMP cannon</label>
    <description>The shell emits a burst of electromagnetic energy that stuns electronic targets like turrets and mechanoids. Once fired, it must be reloaded using steel.</description>
    <commonality>1</commonality>
    <statOffsets>
      <MarketValue>50</MarketValue>
    </statOffsets>
    <abilityProps>
      <abilityDef>LaunchEMPShell</abilityDef>
      <maxCharges>2</maxCharges>
      <soundReload>Standard_Reload</soundReload>
      <chargeNoun>shell</chargeNoun>
      <ammoDef>Steel</ammoDef>
      <ammoCountPerCharge>15</ammoCountPerCharge>
      <baseReloadTicks>60</baseReloadTicks>
    </abilityProps>
  </WeaponTraitDef>

