  <!-- #endregion -->

  <!-- #region Barrel -->
  <!-- > ExtendedBarrel -->
  <ThingDef ParentName="CWF_TraitModule">
    <defName>CWF_Module_ExtendedBarrel</defName>
    <label>extended barrel module</label>
    <description>A extended barrel.</description>
    <descriptionHyperlinks>
      <weaponTraitDef>CWF_Trait_ExtendedBarrel</weaponTraitDef>
    </descriptionHyperlinks>
    <graphicData>
      <texPath>Things/Item/Health/HealthItem</texPath> <!-- tmp tex -->
      <color>(115, 120, 87)</color>
    </graphicData>
    <statBases>
      <WorkToMake>3000</WorkToMake>
    </statBases>
    <costList>
      <Steel>10</Steel>
      <ComponentIndustrial>1</ComponentIndustrial>
    </costList>
    <modExtensions>
      <li Class="CustomizeWeapon.TraitModuleExtension">
        <weaponTraitDef>CWF_Trait_ExtendedBarrel</weaponTraitDef>
