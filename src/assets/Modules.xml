    <label>extended barrel</label>
    <graphicData>
      <texPath>Things/Item/Health/HealthItem</texPath> <!-- tmp tex -->
      <color>(115, 120, 87)</color>
    </graphicData>
    <statBases>
      <WorkToMake>1500</WorkToMake>
    </statBases>
    <costList>
      <Steel>10</Steel>
      <ComponentIndustrial>1</ComponentIndustrial>
    </costList>
    <recipeMaker>
      <researchPrerequisite>Gunsmithing</researchPrerequisite>
    </recipeMaker>
    <modExtensions>
      <li Class="CWF.TraitModuleExtension">
        <weaponTraitDef>CWF_Trait_ExtendedBarrel</weaponTraitDef>
